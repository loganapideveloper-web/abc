# ============================
# AMOHA Mobiles - Backend Configuration
# ============================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Server
NODE_ENV=development
PORT=5000

# MongoDB Connection
# Local: mongodb://localhost:27017/amoha-mobiles
# Atlas: mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/amoha-mobiles?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/amoha-mobiles

# JWT Secrets (MUST be at least 32 characters each — generate your own!)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-to-a-random-string-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-to-another-random-string-at-least-32-chars

# JWT Token Expiry
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Allowed Origins (comma-separated)
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Security
BCRYPT_SALT_ROUNDS=12

# Logging (error | warn | info | debug)
LOG_LEVEL=info
